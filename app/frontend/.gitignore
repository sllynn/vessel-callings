# Dependencies — installed locally via `npm install`
node_modules/

# Parcel build cache — rebuilt on demand
.parcel-cache/

# Build output (frontend/dist/) is *not* ignored: `databricks sync`
# honours .gitignore on upload, so the built artefacts have to live in
# the repo for the app to be deployable via a single `databricks sync`
# invocation. Rebuild via `npm run build` before each deploy.

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Local env overrides
.env
.env.local
.env.*.local

# OS / editor cruft
.DS_Store
*.swp
.idea/
.vscode/
